# ═══════════════════════════════════════════════════════════════
# Autonomous Analytics Agents — Enterprise Multi-Agent Data Intelligence
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.
# At least ONE LLM provider must be configured.

# ── LLM Provider Selection ────────────────────────────────────
# Primary provider: openai | anthropic | groq | together | google | ollama
LLM_PROVIDER=openai
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# Fallback chain (tried in order if primary fails)
# FALLBACK_PROVIDERS=["groq","together","anthropic"]

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# ── Anthropic ─────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ── Groq (fastest inference) ──────────────────────────────────
# GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=llama-3.1-8b-instant

# ── Together AI ───────────────────────────────────────────────
# TOGETHER_API_KEY=your-key-here
# TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# ── Google Gemini ─────────────────────────────────────────────
# GOOGLE_API_KEY=your-key-here
# GOOGLE_MODEL=gemini-1.5-flash

# ── Ollama (local, no key needed) ─────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3

# ── Web Scraping ──────────────────────────────────────────────
# FIRECRAWL_API_KEY=fc-your-key-here
# TAVILY_API_KEY=tvly-your-key-here

# ── RAG / Embeddings ──────────────────────────────────────────
# Uses OPENAI_API_KEY for text-embedding-3-small if available,
# falls back to SentenceTransformers (all-MiniLM-L6-v2)
CHROMA_PERSIST_DIR=./data/chroma
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5

# ── Storage ───────────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
SQLITE_PATH=./data/platform.db

# ── Budget ────────────────────────────────────────────────────
MAX_DAILY_SPEND_USD=5.0
TRACK_COSTS=true

# ── GCP Deployment (Cloud Run) ─────────────────────────────────
# Set these when deploying to Google Cloud. Ignore for local dev.
# GCP_PROJECT=your-gcp-project-id
# GCS_BUCKET_NAME=your-project-analytics-agents-storage
